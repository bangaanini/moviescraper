generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "internal"]
}

enum MediaType {
  movie
  tv

  @@map("media_type")
  @@schema("public")
}

enum IngestionStatus {
  pending
  running
  succeeded
  failed

  @@map("ingestion_status")
  @@schema("public")
}

model Media {
  id                 BigInt              @id @default(autoincrement()) @db.BigInt
  publicId           String              @unique(map: "media_public_id_unique") @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("public_id")
  mediaType          MediaType           @map("media_type")
  canonicalProvider  String              @map("canonical_provider")
  canonicalExternalId String             @map("canonical_external_id")
  originalTitle      String              @map("original_title")
  originalOverview   String?             @map("original_overview")
  releaseYear        Int?                @map("release_year")
  originalLanguage   String?             @map("original_language")
  status             String?
  runtimeMinutes     Int?                @map("runtime_minutes")
  posterUrl          String?             @map("poster_url")
  backdropUrl        String?             @map("backdrop_url")
  popularity         Decimal?            @db.Decimal(10, 3)
  voteAverage        Decimal?            @map("vote_average") @db.Decimal(4, 2)
  voteCount          Int?                @map("vote_count")
  adult              Boolean             @default(false)
  metadataSource     String              @map("metadata_source")
  subtitleSource     String?             @map("subtitle_source")
  ingestionConfidence Decimal?           @map("ingestion_confidence") @db.Decimal(4, 3)
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  mediaExternalIds   MediaExternalId[]
  mediaLocalizations MediaLocalization[]
  seasons            Season[]
  episodes           Episode[]
  subtitleTracks     SubtitleTrack[]
  feedItems          MediaFeedItem[]

  @@unique([canonicalProvider, canonicalExternalId], map: "media_canonical_unique")
  @@map("media")
  @@schema("public")
}

model MediaExternalId {
  id          BigInt   @id @default(autoincrement()) @db.BigInt
  mediaId     BigInt   @map("media_id") @db.BigInt
  provider    String
  externalId  String   @map("external_id")
  externalUrl String?  @map("external_url")
  isPrimary   Boolean  @default(false) @map("is_primary")
  rawPayload  Json?    @map("raw_payload")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  media       Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId], map: "media_external_ids_unique")
  @@unique([mediaId, provider], map: "media_external_ids_media_provider_key")
  @@map("media_external_ids")
  @@schema("public")
}

model MediaLocalization {
  id             BigInt   @id @default(autoincrement()) @db.BigInt
  mediaId        BigInt   @map("media_id") @db.BigInt
  lang           String
  title          String
  overview       String?
  sourceProvider String   @map("source_provider")
  sourceKind     String   @map("source_kind")
  isDefault      Boolean  @default(false) @map("is_default")
  confidence     Decimal? @db.Decimal(4, 3)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  media          Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, lang], map: "media_localizations_unique")
  @@map("media_localizations")
  @@schema("public")
}

model Season {
  id           BigInt    @id @default(autoincrement()) @db.BigInt
  mediaId      BigInt    @map("media_id") @db.BigInt
  seasonNumber Int       @map("season_number")
  title        String?
  overview     String?
  airDate      DateTime? @map("air_date") @db.Date
  posterUrl    String?   @map("poster_url")
  episodeCount Int?      @map("episode_count")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  media        Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episodes     Episode[]

  @@unique([mediaId, seasonNumber], map: "seasons_unique")
  @@map("seasons")
  @@schema("public")
}

model Episode {
  id                 BigInt              @id @default(autoincrement()) @db.BigInt
  mediaId            BigInt              @map("media_id") @db.BigInt
  seasonId           BigInt?             @map("season_id") @db.BigInt
  seasonNumber       Int                 @map("season_number")
  episodeNumber      Int                 @map("episode_number")
  title              String
  overview           String?
  releaseDate        DateTime?           @map("release_date") @db.Date
  runtimeMinutes     Int?                @map("runtime_minutes")
  stillUrl           String?             @map("still_url")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  media              Media               @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  season             Season?             @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  episodeExternalIds EpisodeExternalId[]
  subtitleTracks     SubtitleTrack[]

  @@unique([mediaId, seasonNumber, episodeNumber], map: "episodes_unique")
  @@map("episodes")
  @@schema("public")
}

model EpisodeExternalId {
  id          BigInt   @id @default(autoincrement()) @db.BigInt
  episodeId   BigInt   @map("episode_id") @db.BigInt
  provider    String
  externalId  String   @map("external_id")
  externalUrl String?  @map("external_url")
  rawPayload  Json?    @map("raw_payload")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  episode     Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId], map: "episode_external_ids_unique")
  @@map("episode_external_ids")
  @@schema("public")
}

model SubtitleTrack {
  id                 BigInt    @id @default(autoincrement()) @db.BigInt
  mediaId            BigInt?   @map("media_id") @db.BigInt
  episodeId          BigInt?   @map("episode_id") @db.BigInt
  provider           String
  languageCode       String    @map("language_code")
  externalSubtitleId String?   @map("external_subtitle_id")
  externalFileId     String?   @map("external_file_id")
  releaseName        String?   @map("release_name")
  fileName           String?   @map("file_name")
  format             String?
  isHearingImpaired  Boolean   @default(false) @map("is_hearing_impaired")
  isAiGenerated      Boolean   @default(false) @map("is_ai_generated")
  sourceKind         String    @default("discovered") @map("source_kind")
  downloadUrl        String?   @map("download_url")
  storagePath        String?   @map("storage_path")
  downloadStatus     String    @default("discovered") @map("download_status")
  score              Decimal?  @db.Decimal(10, 3)
  downloadsCount     Int?      @map("downloads_count")
  rawPayload         Json?     @map("raw_payload")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  media              Media?    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episode            Episode?  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([provider, externalFileId], map: "subtitle_tracks_provider_file_unique_idx")
  @@map("subtitle_tracks")
  @@schema("public")
}

model MediaFeedItem {
  id               BigInt   @id @default(autoincrement()) @db.BigInt
  feedKind         String   @map("feed_kind")
  pageNumber       Int      @map("page_number")
  position         Int
  mediaId          BigInt   @map("media_id") @db.BigInt
  sourceProvider   String   @map("source_provider")
  sourceExternalId String   @map("source_external_id")
  fetchedAt        DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  media            Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([feedKind, pageNumber, position], map: "media_feed_items_unique_position")
  @@unique([feedKind, pageNumber, mediaId], map: "media_feed_items_unique_media")
  @@map("media_feed_items")
  @@schema("public")
}

model IngestionJob {
  id           BigInt          @id @default(autoincrement()) @db.BigInt
  provider     String
  jobType      String          @map("job_type")
  status       IngestionStatus @default(pending)
  inputPayload Json            @default("{}") @map("input_payload")
  outputPayload Json?          @map("output_payload")
  errorMessage String?         @map("error_message")
  startedAt    DateTime?       @map("started_at") @db.Timestamptz(6)
  finishedAt   DateTime?       @map("finished_at") @db.Timestamptz(6)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("ingestion_jobs")
  @@schema("internal")
}

model ProviderPayload {
  id         BigInt   @id @default(autoincrement()) @db.BigInt
  provider   String
  entityType String   @map("entity_type")
  entityKey  String   @map("entity_key")
  payload    Json
  fetchedAt  DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("provider_payloads")
  @@schema("internal")
}
